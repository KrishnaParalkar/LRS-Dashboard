# =============================================================================
# LRS Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and customise the values.
#   cp .env.example .env
# =============================================================================

# ---- Redash ------------------------------------------------------------------
REDASH_VERSION=26.3.0
REDASH_PORT=5005
REDASH_COOKIE_SECRET=CHANGE_ME_cookie_secret_here
REDASH_SECRET_KEY=CHANGE_ME_secret_key_here
REDASH_DATABASE_URL=postgresql://postgres:redash_secret@postgres/redash
REDASH_REDIS_URL=redis://redis:6379/0
REDASH_ENFORCE_CSRF=true
REDASH_GUNICORN_TIMEOUT=60
PYTHONUNBUFFERED=0
REDASH_LOG_LEVEL=INFO
# CRITICAL: Set to false to allow Redash to connect to internal Docker services (Elasticsearch)
REDASH_ENFORCE_PRIVATE_IP_BLOCK=false

# ---- SQL LRS (yetanalytics/lrsql) -------------------------------------------
LRSQL_PORT=8080
LRSQL_DB_HOST=postgres-lrs
LRSQL_DB_PORT=5432
LRSQL_DB_NAME=lrsql
LRSQL_DB_USER=lrsql
LRSQL_DB_PASSWORD=lrsql_secret
LRSQL_API_KEY_DEFAULT=admin
LRSQL_API_SECRET_DEFAULT=admin
LRSQL_ADMIN_USER_DEFAULT=admin
LRSQL_ADMIN_PASS_DEFAULT=admin

# Default Admin (Created by setup.sh)
REDASH_ADMIN_NAME=Admin
REDASH_ADMIN_EMAIL=admin@example.com
REDASH_ADMIN_PASSWORD=admin123

# ---- Ralph LRS ---------------------------------------------------------------
RALPH_VERSION=latest
RALPH_PORT=8100
# These are used for Basic Auth in Ralph
RALPH_AUTH_USER=ralph
RALPH_AUTH_PASSWORD=secret

# ---- Seeding Script (seed.py) ------------------------------------------------
# These should match RALPH_AUTH_USER and RALPH_AUTH_PASSWORD
LRS_API_KEY=ralph
LRS_API_SECRET=secret
LRS_PUBLIC_URL=http://127.0.0.1:8100

# ---- PostgreSQL (Redash backend) ---------------------------------------------
PG_VERSION=17-alpine
POSTGRES_PASSWORD=redash_secret

# ---- Elasticsearch (shared by Ralph + Redash) --------------------------------
ES_VERSION=8.1.0
ES_PORT=9200

# ---- Redis (Redash queue / cache) --------------------------------------------
REDIS_VERSION=7-alpine

# ---- Nginx (Redash reverse proxy) -------------------------------------------
NGINX_PORT=80
